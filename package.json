{
  "name": "label-lens-ttb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "smoke:relocation": "node scripts/relocation-smoke.mjs",
    "eval:inventory": "node scripts/fixtures/generate-eval-manifest.mjs",
    "eval:inspect": "node scripts/fixtures/generate-ocr-inspection-summary.mjs",
    "eval:baseline": "EVAL_BASELINE=1 vitest run src/fixtures/eval/baseline-report.gen.test.ts",
    "eval:ocr-region-benchmark": "EVAL_REGION_BENCHMARK=1 vitest run src/fixtures/eval/ocr-region-benchmark.gen.test.ts",
    "eval:vision-region-benchmark": "npx vite-node --config vitest.config.ts scripts/eval/run-vision-region-benchmark.ts",
    "eval:local-vlm-smoke": "npx vite-node --config vitest.config.ts scripts/eval/run-local-vlm-smoke.ts",
    "eval:local-vlm-contamination": "npx vite-node --config vitest.config.ts scripts/eval/run-local-vlm-contamination.ts",
    "eval:local-vlm-resource-stress": "npx vite-node --config vitest.config.ts scripts/eval/run-local-vlm-resource-stress.ts",
    "eval:local-vlm-response-completion": "npx vite-node --config vitest.config.ts scripts/eval/run-local-vlm-response-completion.ts",
    "eval:local-vlm-single-proposal-decomposition": "npx vite-node --config vitest.config.ts scripts/eval/run-local-vlm-single-proposal-decomposition.ts",
    "eval:local-vlm-request-parity-reproducibility": "npx vite-node --config vitest.config.ts scripts/eval/run-local-vlm-request-parity-reproducibility.ts",
    "docs:check": "node --experimental-strip-types --no-warnings scripts/check-docs.ts",
    "docs:check:test": "vitest run src/docs/documentation-validator.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^2.6.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
